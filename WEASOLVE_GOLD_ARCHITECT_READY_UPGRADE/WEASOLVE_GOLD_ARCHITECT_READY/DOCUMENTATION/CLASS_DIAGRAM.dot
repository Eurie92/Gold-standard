digraph G {
  rankdir=TB;
  node [shape=record, fontsize=10, fontname="Arial"];
  FoodItem [label="{FoodItem| - id:int\l - name:string\l - weather:string\l - budgetLevel:string\l - price:double\l - restaurant:string\l - healthNote:string\l| + getters/setters()\l + display()\l + toFileString()\l}"];
  FoodManager [label="{FoodManager| - foods: vector of FoodItem\l - favorites: vector of FoodItem\l| + CRUD()\l + loadFromFile()\l + saveToFile()\l + recommendSmartRanking()\l}"];
  InputValidator [label="{InputValidator| utility class| + getIntInRange()\l + getWeatherInput()\l + getBudgetInput()\l + getPositiveDouble()\l}"];
  UserPreference [label="{UserPreference| weather:string\l budgetLevel:string\l availableMoney:double\l}"];
  RecommendationResult [label="{RecommendationResult| food:FoodItem\l score:int\l explanation:string\l}"];
  RecommendationEngine [label="{RecommendationEngine| - rules: vector of RecommendationRule pointers\l| + recommend()\l}"];
  RecommendationRule [label="{RecommendationRule (Abstract)| + virtual score() = 0\l + virtual explain() = 0\l}"];
  WeatherMatchRule [label="{WeatherMatchRule| + score()\l + explain()\l}"];
  BudgetMatchRule [label="{BudgetMatchRule| + score()\l + explain()\l}"];
  AffordabilityRule [label="{AffordabilityRule| + score()\l + explain()\l}"];
  HealthSuitabilityRule [label="{HealthSuitabilityRule| + score()\l + explain()\l}"];

  FoodManager -> FoodItem [label="manages many"];
  FoodManager -> RecommendationEngine [label="calls"];
  FoodManager -> InputValidator [label="uses"];
  RecommendationEngine -> RecommendationRule [label="polymorphic rules"];
  RecommendationEngine -> RecommendationResult [label="returns ranked list"];
  RecommendationEngine -> UserPreference [label="reads preferences"];
  RecommendationResult -> FoodItem [label="contains"];
  WeatherMatchRule -> RecommendationRule [arrowhead=empty, label="inherits"];
  BudgetMatchRule -> RecommendationRule [arrowhead=empty, label="inherits"];
  AffordabilityRule -> RecommendationRule [arrowhead=empty, label="inherits"];
  HealthSuitabilityRule -> RecommendationRule [arrowhead=empty, label="inherits"];
}
