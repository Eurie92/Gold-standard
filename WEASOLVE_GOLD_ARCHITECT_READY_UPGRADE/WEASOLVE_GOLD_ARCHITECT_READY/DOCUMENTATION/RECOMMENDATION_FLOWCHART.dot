digraph G {
  rankdir=TB;
  node [shape=box, style="rounded", fontname="Arial", fontsize=10];
  A [label="Start Smart Recommendation"];
  B [label="Get current weather from main.cpp"];
  C [label="Ask user budget level and available money"];
  D [label="Create UserPreference object"];
  E [label="FoodManager calls RecommendationEngine"];
  F [label="Loop through every FoodItem in vector"];
  G [label="Apply WeatherMatchRule (+40)"];
  H [label="Apply BudgetMatchRule (+25)"];
  I [label="Apply AffordabilityRule (+25)"];
  J [label="Apply HealthSuitabilityRule (+10)"];
  K [label="Compute total score and explanation"];
  L [shape=diamond, label="Score >= 70 and affordable?"];
  M [label="Add to RecommendationResult list"];
  N [label="Sort results by highest score, then cheaper price"];
  O [label="Display ranked foods with reasons"];
  P [label="End"];
  A -> B -> C -> D -> E -> F -> G -> H -> I -> J -> K -> L;
  L -> M [label="Yes"];
  L -> F [label="No / next food"];
  M -> F [label="next food"];
  F -> N [label="after all records"];
  N -> O -> P;
}
